{
  "manifest_version": 2,
  "name": "Minimal Pomodoro",
  "version": "3.3",
  "description": "Background Pomodoro Timer",

  "permissions": ["storage"],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Pomodoro Timer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    "sounds/bell.mp3",
    "sounds/chime.mp3",
    "sounds/digital.mp3",
    "sounds/soft.mp3"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "minimal-pomodoro@akshant",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
